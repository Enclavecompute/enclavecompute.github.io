---
import Base from '../layouts/Base.astro';
---

<Base title="Enclave Compute — AI That Never Leaves Your Building">
  <!-- HERO -->
  <section class="hero">
    <div class="badge">🔒 100% Local Inference — Zero Cloud Dependency</div>
    <h1>AI that <span class="highlight">never leaves</span> your building</h1>
    <p>
      We deploy private, on-premise AI systems for healthcare practices, law firms,
      and professional services. Your data stays in your office. Period.
    </p>
    <div class="btn-group">
      <a href="#contact" class="btn btn-primary">Book a Free Demo</a>
      <a href="#how-it-works" class="btn btn-outline">See How It Works</a>
    </div>
  </section>

  <!-- WHY LOCAL -->
  <section>
    <h2>Why local AI?</h2>
    <p class="section-subtitle">
      Cloud AI sends your sensitive data to external servers. We keep everything on a device in your office.
    </p>
    <div class="feature-grid">
      <div class="feature-card">
        <div class="icon">🔐</div>
        <h3>Complete Data Privacy</h3>
        <p>Patient records, client files, and privileged communications never leave your network. No cloud APIs, no third-party data processing.</p>
      </div>
      <div class="feature-card">
        <div class="icon">⚡</div>
        <h3>No Per-User Fees</h3>
        <p>One-time deployment. No monthly SaaS subscriptions that scale with your headcount. The hardware is yours.</p>
      </div>
      <div class="feature-card">
        <div class="icon">🏥</div>
        <h3>Compliance Simplified</h3>
        <p>No Business Associate Agreements with cloud AI vendors. No vendor risk assessments. Your compliance officer will thank you.</p>
      </div>
      <div class="feature-card">
        <div class="icon">🛡️</div>
        <h3>No Vendor Lock-In</h3>
        <p>Open-source models on hardware you own. If you part ways with us, everything keeps running. Your data, your hardware, your choice.</p>
      </div>
      <div class="feature-card">
        <div class="icon">📡</div>
        <h3>Works Offline</h3>
        <p>Internet goes down? Your AI keeps working. No cloud dependency means no outages, no latency spikes, no downtime.</p>
      </div>
      <div class="feature-card">
        <div class="icon">🤝</div>
        <h3>Local Support</h3>
        <p>We're based in the Triangle, NC. When you need help, we're 20 minutes away — not a ticket queue in another timezone.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works">
    <h2>How it works</h2>
    <p class="section-subtitle">From first conversation to running AI in your office — in under two weeks.</p>
    <div class="steps">
      <div class="step">
        <h3>Discovery Call</h3>
        <p>We learn your workflows, pain points, and compliance requirements. No cost, no commitment.</p>
      </div>
      <div class="step">
        <h3>Free Insight Report</h3>
        <p>We deliver a sample AI analysis using your public data (e.g., review intelligence) so you can see the value before you buy.</p>
      </div>
      <div class="step">
        <h3>On-Site Deployment</h3>
        <p>We install a pre-configured device in your office, set up the AI models for your use cases, and configure access controls.</p>
      </div>
      <div class="step">
        <h3>Staff Training & Go-Live</h3>
        <p>90-minute on-site training. Your team is productive on day one. 30 days of included support.</p>
      </div>
    </div>

    <div class="arch-diagram">
┌─────────── Your Office ──────────────┐
│                                      │
│   Staff Devices (laptop / tablet)    │
│       └─ Browser-based interface     │
│                  │                   │
│          office Wi-Fi (LAN only)     │
│                  │                   │
│   ┌──────────────▼──────────────┐    │
│   │     Local AI Appliance      │    │
│   │  Models + Transcription +   │    │
│   │  Vector Store + Encryption  │    │
│   └─────────────────────────────┘    │
│                                      │
│   ☁️ Internet? Not required.         │
└──────────────────────────────────────┘</div>
  </section>

  <!-- VERTICALS -->
  <section id="verticals">
    <h2>Who we work with</h2>
    <p class="section-subtitle">
      Any business that handles sensitive data and wants AI without the cloud risk.
    </p>
    <div class="vertical-cards">
      <div class="vertical-card">
        <h3>🏥 Healthcare</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 1rem;">Dental, orthodontic, and medical practices</p>
        <ul>
          <li>Clinical note drafting (SOAP notes from voice)</li>
          <li>Patient review intelligence & response</li>
          <li>Pre-authorization letter drafting</li>
          <li>Morning huddle briefs</li>
          <li>Staff knowledge base</li>
        </ul>
      </div>
      <div class="vertical-card">
        <h3>⚖️ Legal</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 1rem;">Solo practitioners and small firms</p>
        <ul>
          <li>Contract review & clause extraction</li>
          <li>Deposition summarization</li>
          <li>Case research assistance</li>
          <li>Client communication drafting</li>
          <li>Document organization & search</li>
        </ul>
      </div>
      <div class="vertical-card">
        <h3>🏢 Professional Services</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 1rem;">Accounting, consulting, financial advisory</p>
        <ul>
          <li>Client report generation</li>
          <li>Document summarization</li>
          <li>Internal knowledge base</li>
          <li>Review monitoring & response</li>
          <li>Process automation</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <h2>About Enclave Compute</h2>
    <div class="about-grid">
      <div class="about-text">
        <p>
          Enclave Compute is a local AI deployment consultancy based in the Triangle area of North Carolina.
          We help privacy-sensitive businesses harness AI without sending their data to the cloud.
        </p>
        <p>
          Founded by engineers with backgrounds in confidential computing, enterprise security,
          and applied AI — we understand both the technology and the compliance requirements
          that come with handling sensitive data.
        </p>
        <p>
          We believe AI should work for your business on your terms, running on hardware you own,
          with data that never leaves your control.
        </p>
      </div>
      <div class="about-highlights">
        <div class="about-highlight">
          <h4>🔬 Technical Depth</h4>
          <p>Background in confidential computing, Apple silicon ML, and enterprise AI deployments.</p>
        </div>
        <div class="about-highlight">
          <h4>📍 Triangle, NC</h4>
          <p>Local presence means on-site deployments, in-person training, and same-day support.</p>
        </div>
        <div class="about-highlight">
          <h4>🧱 Open Source Stack</h4>
          <p>Built on proven open-source models (Llama, Whisper, Gemma). No proprietary lock-in.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="cta-section" id="contact">
      <h2>Ready to see it in action?</h2>
      <p>Book a free demo and we'll show you what local AI can do — using your own data, on a device with no internet connection.</p>
      <a href="mailto:hello@enclavecompute.net" class="btn btn-primary">hello@enclavecompute.net</a>
    </div>
  </section>
</Base>
